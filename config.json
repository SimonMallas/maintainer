{
  "runtime": {
    "state_file": "maintainer_state.json",
    "loop_sleep_seconds": 1
  },
  "enabled_modules": [
    "process",
    "memory",
    "disk",
    "config_drift",
    "sentinel_probe"
  ],
  "process": {
    "services": ["sentinel"],
    "interval": 30
  },
  "gpu": {
    "interval": 20,
    "temp_warn": 80,
    "temp_crit": 85
  },
  "memory": {
    "interval": 30,
    "ram_warn": 85,
    "swap_crit": 80
  },
  "disk": {
    "interval": 60,
    "path": "/",
    "warn_pct": 80,
    "crit_pct": 90
  },
  "config_drift": {
    "interval": 120,
    "files": [
      "/home/simon/sentinel-control-plane/config/policies.yaml"
    ]
  },
  "sentinel_probe": {
    "interval": 30,
    "health_url": "http://127.0.0.1:8085/healthz",
    "prom_url": "",
    "prom_match": "up{job=\"sentinel-control-plane\"}",
    "prom_min_value": 1.0,
    "latency_warn_ms": 0,
    "http_timeout_sec": 3
  },
  "remediation": {
    "dry_run": true,
    "process_restart_cooldown_sec": 300,
    "process_restart_max_retries": 3,
    "process_restart_retry_window_sec": 1800,
    "on_critical_cmd": ""
  },
  "alert_sink": {
    "webhook_url": "",
    "cooldown_sec": 300,
    "http_timeout_sec": 5
  },
  "status_api": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 9101\n  },\n  "multi_node": {\n    "delta_check": true,\n    "nodes": ["node1", "node2"],\n    "sync_interval": 60\n  }\n}
